# SpecForge — AI mode configuration.
# Deterministic mode needs NONE of this and works fully offline.
# Copy this file to `.env` and fill in to enable AI-assisted mode.

# Any OpenAI-compatible /chat/completions endpoint (OpenAI, Azure OpenAI via a
# compatible gateway, a local server, or your org's internal model gateway).
MODEL_BASE_URL=https://api.openai.com/v1
MODEL_API_KEY=

# The two-model pattern: one model drafts, a second independently reviews.
# Set them to DIFFERENT models for genuine independence, or leave equal.
MODEL_DRAFT=gpt-4o-mini
MODEL_VALIDATE=gpt-4o-mini

# Or set one default for both instead of the two above:
# MODEL_NAME=gpt-4o-mini

# Web server port (optional).
PORT=4173
